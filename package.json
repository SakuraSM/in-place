{
  "name": "in-place",
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @inplace/web",
    "dev:server": "NODE_OPTIONS=--conditions=development npm run dev --workspace @inplace/server",
    "build:web": "npm run build --workspace @inplace/web",
    "build:db": "npm run build --workspace @inplace/db",
    "build:server": "npm run build --workspace @inplace/db && npm run build --workspace @inplace/server",
    "build": "npm run build:server && npm run build:web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:up": "docker compose -f infra/postgres/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/postgres/docker-compose.yml down",
    "db:logs": "docker compose -f infra/postgres/docker-compose.yml logs -f postgres",
    "db:generate": "npm run db:generate --workspace @inplace/db",
    "db:migrate": "npm run db:migrate --workspace @inplace/db"
  }
}
