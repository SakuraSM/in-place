NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://inplace:<database-password>@127.0.0.1:5433/inplace
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=replace-with-a-random-32-character-secret
APP_ENCRYPTION_KEY=replace-with-a-random-32-character-secret
MAX_UPLOAD_SIZE_MB=10
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Docker Compose deployment uses the service hostname `postgres` instead:
# DATABASE_URL=postgres://inplace:<database-password>@postgres:5432/inplace
