NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://inplace:<database-password>@127.0.0.1:5433/inplace
CORS_ORIGIN=http://127.0.0.1:4173
JWT_SECRET=replace-with-a-random-32-character-secret
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=10

# Local PostgreSQL via infra/postgres uses the service hostname `postgres` instead:
# DATABASE_URL=postgres://inplace:<database-password>@postgres:5432/inplace
