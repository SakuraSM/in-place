VITE_API_BASE_URL=http://127.0.0.1:4000

# Docker Compose deployment usually serves the frontend and proxies API requests
# through the same origin, so `/api` is the recommended value there:
# VITE_API_BASE_URL=/api

# Legacy migration note:
# The current UI still contains transitional Supabase-based feature code.
# Keep these empty unless you are running the legacy data flow.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
