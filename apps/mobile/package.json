{
  "name": "@inplace/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:android": "eas build --platform android --profile production --non-interactive",
    "build:ios": "eas build --platform ios --profile production --non-interactive",
    "build:all": "eas build --platform all --profile production --non-interactive"
  },
  "dependencies": {
    "@inplace/api-client": "*",
    "@inplace/app-core": "*",
    "@inplace/domain": "*",
    "@tanstack/react-query": "^5.90.21",
    "expo": "^53.0.0",
    "expo-constants": "~17.1.8",
    "expo-image-picker": "^16.0.0",
    "expo-linking": "~7.1.7",
    "expo-router": "^5.0.0",
    "expo-secure-store": "^14.0.0",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
